  RewriteRule ^mobile-notary-rock-hill-sc$ /mobile-notary-rock-hill-sc.html [L]
  # --- end location pages ---




  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
